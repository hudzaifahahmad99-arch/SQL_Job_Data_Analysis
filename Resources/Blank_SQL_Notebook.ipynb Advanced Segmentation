      "source": [
        "%%sql\n",
        "\n",
        "SELECT\n",
        "    orderdate,\n",
        "    quantity,\n",
        "    netprice,\n",
        "    CASE\n",
        "        WHEN quantity >= 2 AND netprice >= 100 THEN 'Multiple High Value Order'\n",
        "        WHEN netprice >= 100 THEN 'Single High Value Item'\n",
        "        WHEN quantity >= 2 THEN 'Multiple Standard Items'\n",
        "        ELSE 'Standard Standard Item'\n",
        "    END AS order_type\n",
        "FROM sales\n",
        "LIMIT 10\n"
      ]
